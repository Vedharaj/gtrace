{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GTraceRunMetadata",
  "type": "object",
  "required": [
    "benchmark_name",
    "suite",
    "category",
    "execution_time_seconds",
    "host_name",
    "cpu_model",
    "isa",
    "memory",
    "cache",
    "gem5_version",
    "git_commit",
    "date",
    "binary_hash",
    "input_hash",
    "return_code",
    "trace_size_bytes",
    "stats_size_bytes",
    "execution_status",
    "attempt",
    "reproducibility"
  ],
  "properties": {
    "benchmark_name": { "type": "string" },
    "suite": { "type": "string" },
    "category": { "type": "string" },
    "execution_time_seconds": { "type": "number" },
    "simulation_ticks": { "type": ["integer", "null"] },
    "simulation_seconds": { "type": ["number", "null"] },
    "committed_instructions": { "type": ["integer", "null"] },
    "host_name": { "type": "string" },
    "cpu_model": { "type": "string" },
    "isa": { "type": "string" },
    "memory": { "type": "string" },
    "cache": {
      "type": "object",
      "required": ["l1d_size", "l1i_size", "l2_size"],
      "properties": {
        "l1d_size": { "type": "string" },
        "l1i_size": { "type": "string" },
        "l2_size": { "type": "string" }
      }
    },
    "gem5_version": { "type": "string" },
    "git_commit": { "type": "string" },
    "date": { "type": "string", "format": "date-time" },
    "binary_hash": { "type": "string" },
    "input_hash": { "type": "string" },
    "return_code": { "type": ["integer", "null"] },
    "trace_size_bytes": { "type": "integer" },
    "stats_size_bytes": { "type": "integer" },
    "execution_status": { "type": "string" },
    "attempt": { "type": "integer" },
    "error_message": { "type": ["string", "null"] },
    "reproducibility": {
      "type": "object",
      "required": [
        "python_version",
        "operating_system",
        "host_cpu",
        "host_memory",
        "environment_variables",
        "installed_packages"
      ],
      "properties": {
        "python_version": { "type": "string" },
        "operating_system": { "type": "string" },
        "host_cpu": { "type": "string" },
        "host_memory": { "type": "string" },
        "environment_variables": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "installed_packages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
