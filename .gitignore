profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment this line if you want to share the version.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates want to install dependency, they may opt to ignore Pipfile.lock.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be in version control.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be in version control.
#   pdm.lock

# PEP 582; project local imports directory
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

